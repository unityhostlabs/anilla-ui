{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",

        "lib": ["DOM", "ES2022"],

        "allowJs": true,
        "checkJs": true,

        "noEmit": true,

        "moduleResolution": "Bundler",

        "useDefineForClassFields": true,

        "strict": false,

        "paths": {
            "@anilla/ui": ["./src/index.js"]
        }
    },

    "include": [
        "src/**/*"
    ]
}